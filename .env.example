# Freepilot Configuration — No API key needed for Ollama!

# Provider: ollama (default, free), deepseek (free tier), or openai (requires key)
FREEPILOT_PROVIDER=ollama

# ========== OLLAMA (local, completely free) ==========
# Install: https://ollama.ai
# Make sure Ollama is running before using freepilot
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=codellama
# Other good models: llama3.1, deepseek-coder, qwen2.5-coder, mistral

# ========== DEEPSEEK (free API tier) ==========
# Get free API key: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# FREEPILOT_MODEL=deepseek-chat

# ========== OPENAI (requires API key) ==========
# OPENAI_API_KEY=sk-your-api-key-here
# FREEPILOT_MODEL=gpt-4o-mini

# ========== General ==========
# FREEPILOT_MAX_TOKENS=4096
# FREEPILOT_TEMPERATURE=0.7
# FREEPILOT_AUTO_ACCEPT=false
